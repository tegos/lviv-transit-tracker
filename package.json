{
  "name": "lviv-transit-tracker",
  "version": "0.0.2",
  "private": true,
  "description": "Real-time Lviv public transit tracker - bus positions on Google Maps via Socket.IO and the api.lad.lviv.ua REST API",
  "keywords": [
    "lviv",
    "transit",
    "realtime",
    "socket.io",
    "express",
    "google-maps",
    "bus-tracker"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tegos/lviv-transit-tracker.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prestart": "vite build",
    "start": "node ./bin/www",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "NODE_ENV=test node --test test/*.test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "debug": "^4.4.3",
    "dotenv": "^16.5.0",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "serve-favicon": "^2.5.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
